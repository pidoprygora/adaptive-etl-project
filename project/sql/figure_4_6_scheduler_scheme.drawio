        <mxCell id="b2" value="&lt;b&gt;Оцінювання навантаження&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;Обчислюється показник&lt;br/&gt;навантаження для кожної&lt;br/&gt;задачі та середнє&lt;br/&gt;навантаження DAG" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fillColor=#ffffff;strokeColor=#000000;fontSize=13;spacing=7;" vertex="1" parent="1">
          <mxGeometry x="265" y="120" width="190" height="120" as="geometry" />
        </mxCell>

        <mxCell id="b3" value="&lt;b&gt;Рекомендація паралелізму&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;Визначається рекомендована&lt;br/&gt;кількість виконавців для&lt;br/&gt;кожної задачі" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;fillColor=#ffffff;strokeColor=#000000;fontSize=13;spacing=7;" vertex="1" parent="1">
